# Copy this file to .env and fill in your values

# --- LangSmith (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=langsmith_api_key_here
LANGSMITH_PROJECT=rideforge

# --- Weather API (https://openweathermap.org/api) ---
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=gemma4:e2b
VISION_MODEL=gemma4:e2b
EMBED_MODEL=nomic-embed-text

# --- Temperatures ---
PLANNER_TEMPERATURE=0.7
ANALYST_TEMPERATURE=0.2
ADVISOR_TEMPERATURE=0.5
SUPERVISOR_TEMPERATURE=0.0

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- FAISS ---
FAISS_INDEX_PATH=data/ride_knowledge
FAISS_TOP_K=5

# --- LangGraph Store ---
LANGGRAPH_STORE_PATH=data/store
