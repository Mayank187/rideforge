# Copy this file to .env and fill in your values

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_abc123def456abc123def456abc123def456abc1
LANGCHAIN_PROJECT=rideforge

# --- Weather API (https://openweathermap.org/api) ---
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:3b
VISION_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text

# --- Temperatures ---
PLANNER_TEMPERATURE=0.7
ANALYST_TEMPERATURE=0.2
ADVISOR_TEMPERATURE=0.5
SUPERVISOR_TEMPERATURE=0.0

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- FAISS ---
FAISS_INDEX_PATH=data/ride_knowledge
FAISS_TOP_K=5

# --- LangGraph Store ---
LANGGRAPH_STORE_PATH=data/store
